{
  "name": "AppLocker",
  "private": true,
  "version": "0.0.0",
  "description": "AppLocker — block or time-limit any app on a schedule",
  "author": "lambertse",
  "repository": {
    "type": "git",
    "url": "https://github.com/lambertse/app-locktime.git"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "predev": "node scripts/generate-proto.js",
    "dev": "vite",
    "prebuild": "node scripts/generate-proto.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-proto": "node scripts/generate-proto.js",
    "dist": "npm run generate-proto && npm run build && electron-builder --publish never",
    "dist:win": "npm run generate-proto && npm run build && electron-builder --win --publish never",
    "dist:mac": "npm run generate-proto && npm run build && electron-builder --mac --publish never",
    "dist:win:ci": "npm run generate-proto && npm run build && electron-builder --win --publish always",
    "dist:mac:ci": "npm run generate-proto && npm run build && electron-builder --mac --publish always",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\""
  },
  "dependencies": {
    "@lambertse/ibridger": "^0.3.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.95.0",
    "@vscode/spdlog": "^0.15.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "protobufjs": "^7.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.2",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "protobufjs-cli": "^1.1.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.0"
  }
}
